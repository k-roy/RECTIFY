# Production-scale aligner outputs (large, not bundled validation data)
rectify/data/output/aligners/*.bam
rectify/data/output/aligners/*.bam.bai
rectify/data/output/aligners/*.namesorted.bam
rectify/data/output/aligners/*.paf
rectify/data/output/aligners/*.bedgraph
rectify/data/output/aligners/*_junctions.bed
rectify/data/output/aligners/uLTRA_ultra_tmp/
# Re-include the validation_reads-prefixed files (small, bundled test data)
!rectify/data/output/aligners/validation_reads.*.bam
!rectify/data/output/aligners/validation_reads.*.bam.bai
!rectify/data/output/aligners/annotation.junc.bed
