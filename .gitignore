dev_runs/

# Large reference data (downloaded separately, not for version control)
rectify/data/*.fsa
rectify/data/*.fsa.fai
rectify/data/*.gff
rectify/data/*.gtf
rectify/data/*.junc.bed
rectify/data/desalt_index/
